# QuantX Environment Variables
# Copy this to .env and fill in your values
# Run: cp .env.example .env

# ── Required ──────────────────────────────────────────────
# Get free API key at: https://tavily.com
TAVILY_API_KEY=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

# ── Optional: Langfuse Observability ──────────────────────
# Sign up free at: https://cloud.langfuse.com
# Or self-host with Docker: https://langfuse.com/docs/deployment/self-host
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Ollama settings (defaults work if Ollama is running locally) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
